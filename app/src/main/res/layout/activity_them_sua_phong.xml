<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Thêm phòng trọ"
            android:background="@color/banner"
            app:titleCentered="true"
            app:titleTextColor="@android:color/white"
            app:titleTextAppearance="@style/ToolbarTitleBold"/>

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Mã phòng -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilMaPhong"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Mã phòng *">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMaPhong"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="1" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Tên phòng -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilTenPhong"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Tên phòng *">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTenPhong"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="1" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Giá thuê -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilGiaThue"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Giá thuê (VNĐ/tháng) *">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etGiaThue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:maxLines="1" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Tình trạng -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tình trạng phòng *"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="4dp" />

            <RadioGroup
                android:id="@+id/rgTinhTrang"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/rbConTrong"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Còn trống"
                    android:checked="true"
                    android:layout_marginEnd="32dp" />

                <RadioButton
                    android:id="@+id/rbDaThue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã thuê" />

            </RadioGroup>

            <!-- Tên người thuê -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilTenNguoiThue"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Tên người thuê"
                android:enabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTenNguoiThue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:maxLines="1" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Số điện thoại -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilSoDienThoai"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:hint="Số điện thoại"
                android:enabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSoDienThoai"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:maxLines="1" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Nút Lưu -->
            <Button
                android:id="@+id/btnLuu"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lưu thông tin"
                android:textSize="16sp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
